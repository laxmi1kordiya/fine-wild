r":"#000000","question_color":"#000000","question_font_size":16,"answer_color":"#666666","answer_font_size":14,"hover_color":"#228b22"}}},"block_order":["webrex_ai_seo_optimizer_faq_section_AxiVb7"],"settings":{"color_scheme":"scheme-2","separate_section_with_border":true,"remove_vertical_spacing":false,"remove_horizontal_spacing":false}},"image_with_text_9HnWM3":{"type":"image-with-text","blocks":{"subheading_ALay3x":{"type":"subheading","settings":{"text":""}},"heading_Ai9JVG":{"type":"heading","settings":{"text":"<strong>OTORO<\/strong>","heading_tag":"h4"}},"richtext_3CnJph":{"type":"richtext","settings":{"content":"<p>Otoro<strong> <\/strong>is the most prized and comes from the belly, which is the fattiest part of the tuna, The most legendary cut of tuna, and one of the most highly prized by lovers of fine cuisine. With a pinkish colour and silky, highly delicate texture, the belly, known as “Otoro”, is found at the base of the lower loin and contains the highest fat level.<\/p>"}}},"block_order":["subheading_ALay3x","heading_Ai9JVG","richtext_3CnJph"],"name":"t:sections.image_with_text.presets.image_with_text.name","settings":{"color_scheme":"scheme-2","separate_section_with_border":false,"image":"shopify:\/\/shop_images\/BLUEFIN_TUNA_OTORO_SLICE_FINE_WILD.jpg","reveal_on_scroll":true,"image_position":"start","content_width":"sm","remove_vertical_spacing":true}},"image_with_text_Me4nmF":{"type":"image-with-text","blocks":{"subheading_GjUKrq":{"type":"subheading","settings":{"text":""}},"heading_wBpHd7":{"type":"heading","settings":{"text":"<strong>TUNA TATAKI<\/strong>","heading_tag":"h4"}},"richtext_LiVfyh":{"type":"richtext","settings":{"content":"<p>This very simple recipe works as a delicious starter or can be served with addition of forbidden rice, steamed pak choi and baby corn as a fantastic light and healthy main course.<\/p><p>In this recipe we used the Akami cut of Bluefin Tuna which is the lean red meat from the main body of the tuna. It is also possible to use either the Otoro (the fattier belly section which is intensely rich and melt in the mouth) or the Chūtoro (which is a combination of the Akami lean red meat and the fattier belly, found near the skin on the belly and back).<\/p>"}},"button_ApXf6V":{"type":"button","settings":{"style":"outline","text":"RECIPE","url":"shopify:\/\/blogs\/recipes\/seared-bluefin-tuna-recipe-tataki-style","background":"","text_color":""}}},"block_order":["subheading_GjUKrq","heading_wBpHd7","richtext_LiVfyh","button_ApXf6V"],"name":"t:sections.image_with_text.presets.image_with_text.name","settings":{"color_scheme":"scheme-2","separate_section_with_border":false,"image":"shopify:\/\/shop_images\/SEARED_TUNA_FINE_WILD_UK.jpg","reveal_on_scroll":true,"image_position":"end","content_width":"sm","remove_vertical_spacing":true}},"image_with_text_6tkB8Q":{"type":"image-with-text","blocks":{"subheading_7Khf36":{"type":"subheading","settings":{"text":""}},"heading_gJJ8KG":{"type":"heading","settings":{"text":"<strong>TUNA TARTAR<\/strong>","heading_tag":"h4"}},"richtext_BK6BDe":{"type":"richtext","settings":{"content":"<p>A brasserie classic, tartare should always be made with the best quality sushi grade tuna, such as our exceptional Bluefin Tuna Akimi Saku Block. This simple dish is so easy to prepare, but makes a really impressive summery lunch.<\/p>"}},"button_Be8h78":{"type":"button","settings":{"style":"outline","text":"RECIPE","url":"shopify:\/\/blogs\/recipes\/tuna-tartare-recipe","background":"","text_color":""}}},"block_order":["subheading_7Khf36","heading_gJJ8KG","richtext_BK6BDe","button_Be8h78"],"name":"t:sections.image_with_text.presets.image_with_text.name","settings":{"color_scheme":"scheme-2","separate_section_with_border":false,"image":"shopify:\/\/shop_images\/BLUEFIN_TUNA_TARTARE_WITH_STURIA_CAVIAR_FINE_WILD.jpg","reveal_on_scroll":true,"image_position":"start","content_width":"sm","remove_vertical_spacing":true}},"blocks_dMUnEk":{"type":"_blocks","blocks":{"ai_