{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
PRODUCT TABS
----------------------------------------------------------------------------------------------------------------------
Renders a tabbed content block for product metafields (Ingredients, Instructions, Dietary Info).

Supported variables:
* product: the product to pull metafields from
* block: the block settings
----------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign tab_1_key = block.settings.tab_1_metafield | default: 'ingredients' -%}
{%- assign tab_2_key = block.settings.tab_2_metafield | default: 'instructions' -%}
{%- assign tab_3_key = block.settings.tab_3_metafield | default: 'dietary_info' -%}

{%- assign tab_1_metafield = product.metafields.custom[tab_1_key] -%}
{%- assign tab_2_metafield = product.metafields.custom[tab_2_key] -%}
{%- assign tab_3_metafield = product.metafields.custom[tab_3_key] -%}

{%- assign tab_1_title = block.settings.tab_1_title | default: 'Ingredients' -%}
{%- assign tab_2_title = block.settings.tab_2_title | default: 'Instructions' -%}
{%- assign tab_3_title = block.settings.tab_3_title | default: 'Dietary Info' -%}

{%- comment -%}Render each tab content based on metafield type{%- endcomment -%}

{%- capture tab_1_content -%}
  {%- if tab_1_metafield != blank -%}
    {{ tab_1_metafield | metafield_tag }}
  {%- endif -%}
{%- endcapture -%}

{%- capture tab_2_content -%}
  {%- if tab_2_metafield != blank -%}
    {{ tab_2_metafield | metafield_tag }}
  {%- endif -%}
{%- endcapture -%}

{%- capture tab_3_content -%}
  {%- if tab_3_metafield != blank -%}
    {{ tab_3_metafield | metafield_tag }}
  {%- endif -%}
{%- endcapture -%}

{%- assign tab_1_content = tab_1_content | strip -%}
{%- assign tab_2_content = tab_2_content | strip -%}
{%- assign tab_3_content = tab_3_content | strip -%}

{%- assign has_any_content = false -%}
{%- if tab_1_content != blank or tab_2_content != blank or tab_3_content != blank -%}
  {%- assign has_any_content = true -%}
{%- endif -%}

{%- if has_any_content -%}
  {%- assign tabs_id = 'product-tabs-' | append: block.id -%}

  <style>
    .product-tabs {
      border-radius: 16px;
      {% comment %} background: #f5f5f0; {% endcomment %}
      overflow: hidden;
    }

    .product-tabs__nav {
      display: flex;
      gap: 20px;
      {% comment %} padding: 16px 16px 0; {% endcomment %}
    }

    .product-tabs__btn {
      flex: 1;
      padding: 10px 16px;
      border: none;
      background: transparent;
      font-family: inherit;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      border-radius: 16px 16px 0 0;
      color: var(--tab-text-color, #333);
      transition: background 0.2s, color 0.2s;
      text-align: center;
      white-space: nowrap;
      background: #FEC634;
    }

    .product-tabs__btn[aria-selected="true"] {
      background: var(--tab-bg-color, #F2F1EF);
      color: var(--tab-text-color, #333);
    }

    .product-tabs__btn[aria-selected="false"]:hover {
      background: rgba(232, 181, 75, 0.3);
    }

    .product-tabs__panel {
      display: none;
      padding: 25px;
      background: var(--tab-bg-color, #F2F1EF);
      border-radius: 12px 12px 12px 12px;
      position: relative;
      z-index: 2;
      top: -10px;
    }

    .product-tabs__panel[aria-hidden="false"] {
      display: block;
    }

    .product-tabs__panel .prose {
      font-size: 14px;
      line-height: 1.6;
      color: var(--tab-text-color, #333);
    }

    .product-tabs__dietary-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      justify-content: flex-start;
    }

    .product-tabs__dietary-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      min-width: 70px;
    }

    .product-tabs__dietary-icon {
      width: 60px;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .product-tabs__dietary-icon img {
      width: 60px;
      height: 60px;
      object-fit: contain;
      border-radius: 50%;
    }

    .product-tabs__dietary-label {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      text-align: center;
      color: var(--tab-text-color, #333);
      margin: 0;
    }

    @media screen and (min-width: 700px) {
      .product-tabs__btn {
        font-size: 15px;
        {% comment %} padding: 12px 20px; {% endcomment %}
      }

      .product-tabs__panel {
        padding: 24px 28px 28px;
      }

      .product-tabs__dietary-grid {
        gap: 24px;
      }
    }

    .product-tabs__read-more {
      display: inline-block;
      margin-top: 12px;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
    }
  </style>

  <div class="product-tabs" id="{{ tabs_id }}" {{ block.shopify_attributes }}
    {%- if block.settings.bg_color != blank or block.settings.text_color != blank -%}
      style="--tab-bg-color: {{ block.settings.bg_color }}; --tab-text-color: {{ block.settings.text_color }};"
    {%- endif -%}
  >
    <div class="product-tabs__nav" role="tablist">
      {%- if tab_1_content != blank -%}
        <button
          class="product-tabs__btn"
          role="tab"
          aria-selected="true"
          aria-controls="{{ tabs_id }}-panel-1"
          id="{{ tabs_id }}-tab-1"
          type="button"
        >
          {{- tab_1_title -}}
        </button>
      {%- endif -%}

      {%- if tab_2_content != blank -%}
        <button
          class="product-tabs__btn"
          role="tab"
          aria-selected="{% if tab_1_content == blank %}true{% else %}false{% endif %}"
          aria-controls="{{ tabs_id }}-panel-2"
          id="{{ tabs_id }}-tab-2"
          type="button"
        >
          {{- tab_2_title -}}
        </button>
      {%- endif -%}

      {%- if tab_3_content != blank -%}
        <button
          class="product-tabs__btn"
          role="tab"
          aria-selected="{% if tab_1_content == blank and tab_2_content == blank %}true{% else %}false{% endif %}"
          aria-controls="{{ tabs_id }}-panel-3"
          id="{{ tabs_id }}-tab-3"
          type="button"
        >
          {{- tab_3_title -}}
        </button>
      {%- endif -%}
    </div>

    {%- if tab_1_content != blank -%}
      <div
        class="product-tabs__panel"
        role="tabpanel"
        id="{{ tabs_id }}-panel-1"
        aria-labelledby="{{ tabs_id }}-tab-1"
        aria-hidden="false"
      >
        <div class="prose">{{ tab_1_content }}</div>
      </div>
    {%- endif -%}

    {%- if tab_2_content != blank -%}
      <div
        class="product-tabs__panel"
        role="tabpanel"
        id="{{ tabs_id }}-panel-2"
        aria-labelledby="{{ tabs_id }}-tab-2"
        aria-hidden="{% if tab_1_content == blank %}false{% else %}true{% endif %}"
      >
        <div class="prose">{{ tab_2_content }}</div>
      </div>
    {%- endif -%}

    {%- if tab_3_content != blank -%}
      <div
        class="product-tabs__panel"
        role="tabpanel"
        id="{{ tabs_id }}-panel-3"
        aria-labelledby="{{ tabs_id }}-tab-3"
        aria-hidden="{% if tab_1_content == blank and tab_2_content == blank %}false{% else %}true{% endif %}"
      >
        <div class="prose">
          {{ tab_3_content }}
          {%- if block.settings.show_read_more -%}
            <a href="#" class="product-tabs__read-more" data-read-more-tab="{{ tab_3_title | strip_html | strip | escape }}">Read more</a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>

  <script>
    (function() {
      var container = document.getElementById('{{ tabs_id }}');
      if (!container) return;

      var tabs = container.querySelectorAll('[role="tab"]');
      var panels = container.querySelectorAll('[role="tabpanel"]');

      tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
          tabs.forEach(function(t) { t.setAttribute('aria-selected', 'false'); });
          panels.forEach(function(p) { p.setAttribute('aria-hidden', 'true'); });

          tab.setAttribute('aria-selected', 'true');
          var panelId = tab.getAttribute('aria-controls');
          var panel = document.getElementById(panelId);
          if (panel) panel.setAttribute('aria-hidden', 'false');
        });
      });
      {%- comment -%}Read more - scroll to product-tabs-dynamic and activate matching tab{%- endcomment -%}
      var readMoreLink = container.querySelector('[data-read-more-tab]');
      if (readMoreLink) {
        readMoreLink.addEventListener('click', function(e) {
          e.preventDefault();
          var tabTitle = this.getAttribute('data-read-more-tab').trim().toLowerCase();
          var dynamicTabsSection = document.querySelector('.shopify-section--product-tabs-dynamic');
          if (!dynamicTabsSection) return;

          var dynamicTabs = dynamicTabsSection.querySelectorAll('[role="tab"]');
          var accordionTriggers = dynamicTabsSection.querySelectorAll('[data-accordion-trigger]');

          {%- comment -%}Desktop: find and click the matching tab{%- endcomment -%}
          dynamicTabs.forEach(function(tab) {
            var btnText = tab.textContent.trim().toLowerCase();
            if (btnText === tabTitle) {
              tab.click();
            }
          });

          {%- comment -%}Mobile: expand the matching accordion{%- endcomment -%}
          accordionTriggers.forEach(function(trigger) {
            var triggerText = trigger.querySelector('span').textContent.trim().toLowerCase();
            if (triggerText === tabTitle && trigger.getAttribute('aria-expanded') !== 'true') {
              trigger.click();
            }
          });

          dynamicTabsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }
    })();
  </script>
{%- endif -%}
