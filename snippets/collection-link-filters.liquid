{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
COLLECTION LINK FILTERS
----------------------------------------------------------------------------------------------------------------------

Uses a single nested navigation menu to display collection link filters.
Automatically detects the current collection and shows the correct level.

Menu structure (3 levels):
  FRESH & SEASONAL (level 1)
  ├── Vegetables (level 2) → shows on Fresh & Seasonal page
  │   ├── Asparagus (level 3) → shows on Vegetables page
  │   ├── Tomatoes
  │   └── ...
  ├── Fruits (level 2)
  │   ├── Citrus (level 3) → shows on Fruits page
  │   └── ...
  └── Mushrooms (level 2)

********************************************
Supported variables
********************************************

* open_by_default: if true, all filter groups are expanded by default
{%- endcomment -%}

{%- assign menu = section.settings.collection_link_filter_menu -%}

{%- if menu.links.size > 0 -%}
  {%- assign matched = false -%}

  {%- for level1 in menu.links -%}
    {%- comment -%}Level 1: e.g., FRESH & SEASONAL{%- endcomment -%}

    {%- for level2 in level1.links -%}
      {%- comment -%}Level 2: e.g., Vegetables, Fruits, Herbs, Mushrooms{%- endcomment -%}

      {%- comment -%}Check if current collection matches a level 2 item → show its children (level 3){%- endcomment -%}
      {%- if level2.url contains collection.handle -%}
        {%- if level2.links.size > 0 -%}
          {%- assign matched = true -%}

          {%- capture filter_content -%}
            <div class="v-stack gap-2.5">
              {%- for level3 in level2.links -%}
                <a href="{{ level3.url }}" class="{% if level3.url contains collection.handle %}text-bold{% else %}link-faded{% endif %}">
                  {{- level3.title -}}
                </a>
              {%- endfor -%}
            </div>
          {%- endcapture -%}

          {%- render 'accordion', title: level2.title, content: filter_content, open: open_by_default, show_arrow: true -%}
        {%- endif -%}
        {%- break -%}
      {%- endif -%}

      {%- comment -%}Check if current collection matches a level 3 item → show siblings{%- endcomment -%}
      {%- for level3 in level2.links -%}
        {%- if level3.url contains collection.handle -%}
          {%- assign matched = true -%}

          {%- capture filter_content -%}
            <div class="v-stack gap-2.5">
              {%- for sibling in level2.links -%}
                <a href="{{ sibling.url }}" class="{% if sibling.url contains collection.handle %}text-bold{% else %}link-faded{% endif %}">
                  {{- sibling.title -}}
                </a>
              {%- endfor -%}
            </div>
          {%- endcapture -%}

          {%- render 'accordion', title: level2.title, content: filter_content, open: true, show_arrow: true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if matched -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%}Check if current collection matches level 1 → show level 2 children{%- endcomment -%}
    {%- unless matched -%}
      {%- if level1.url contains collection.handle -%}
        {%- if level1.links.size > 0 -%}
          {%- assign matched = true -%}

          {%- capture filter_content -%}
            <div class="v-stack gap-2.5">
              {%- for level2 in level1.links -%}
                <a href="{{ level2.url }}" class="{% if level2.url contains collection.handle %}text-bold{% else %}link-faded{% endif %}">
                  {{- level2.title -}}
                </a>
              {%- endfor -%}
            </div>
          {%- endcapture -%}

          {%- render 'accordion', title: level1.title, content: filter_content, open: open_by_default, show_arrow: true -%}
        {%- endif -%}
      {%- endif -%}
    {%- endunless -%}
  {%- endfor -%}
{%- endif -%}
