{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
PRODUCT TABS DYNAMIC
----------------------------------------------------------------------------------------------------------------------
A flexible tab section for product pages with support for:
- Custom tab titles
- Dynamic metafield content
- Rich text content
- Adjustable spacing and styling
----------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
  {%- assign section_id = 'product-tabs-' | append: section.id -%}
  {%- assign has_any_content = false -%}

  {%- comment -%}Check if any tab has content{%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'recipes' -%}
      {%- assign has_any_content = true -%}
    {%- elsif block.settings.content_source == 'richtext' and block.settings.richtext_content != blank -%}
      {%- assign has_any_content = true -%}
    {%- elsif block.settings.content_source == 'metafield' and block.settings.metafield_namespace != blank and block.settings.metafield_key != blank -%}
      {%- assign has_any_content = true -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if has_any_content -%}
    <style>
      #{{ section_id }} {
        padding-left: {{ section.settings.spacing_left }}px;
        padding-right: {{ section.settings.spacing_right }}px;
        margin-top: {{ section.settings.spacing_top }}px;
        margin-bottom: {{ section.settings.spacing_bottom }}px;
      }

      #{{ section_id }} .product-tabs-dynamic {
        max-width: {{ section.settings.max_width }}px;
        margin: 0 auto;
      }

      /* Tab nav - horizontal with bottom border */
      #{{ section_id }} .product-tabs-dynamic__nav {
        display: flex;
        gap: {{ section.settings.tab_gap }}px;
        border-bottom: 1px solid #ddd;
      }

      /* Tab buttons - text with underline on active */
      #{{ section_id }} .product-tabs-dynamic__btn {
        padding: {{ section.settings.tab_padding_vertical }}px {{ section.settings.tab_padding_horizontal }}px;
        border: none;
        background: transparent;
        font-family: inherit;
        font-size: {{ section.settings.tab_font_size }}px;
        font-weight: {{ section.settings.tab_font_weight }};
        cursor: pointer;
        color: {{ section.settings.tab_text_color }};
        transition: color 0.2s;
        text-align: center;
        white-space: nowrap;
        position: relative;
        border-radius: 0;
      }

      #{{ section_id }} .product-tabs-dynamic__btn::after {
        content: "";
        position: absolute;
        bottom: -1px;
        left: 0;
        right: 0;
        height: 3px;
        background: {{ section.settings.tab_underline_color | default: section.settings.tab_active_text_color }};
        transform: scaleX(0);
        transition: transform 0.25s ease;
      }

      #{{ section_id }} .product-tabs-dynamic__btn[aria-selected="true"] {
        color: {{ section.settings.tab_underline_color | default: section.settings.tab_active_text_color }};
        background: transparent;
      }

      #{{ section_id }} .product-tabs-dynamic__btn[aria-selected="true"]::after {
        transform: scaleX(1);
      }

      #{{ section_id }} .product-tabs-dynamic__btn[aria-selected="false"]:hover {
        color: {{ section.settings.tab_underline_color | default: section.settings.tab_active_text_color }};
      }

      #{{ section_id }} .product-tabs-dynamic__btn[aria-selected="false"]:hover::after {
        transform: scaleX(1);
      }

      /* Content panel */
      #{{ section_id }} .product-tabs-dynamic__panel {
        display: none;
        padding: {{ section.settings.content_padding }}px 0;
        background: transparent;
        position: relative;
      }

      #{{ section_id }} .product-tabs-dynamic__panel[aria-hidden="false"] {
        display: block;
      }

      #{{ section_id }} .product-tabs-dynamic__panel .prose {
        font-size: {{ section.settings.content_font_size }}px;
        line-height: 1.7;
        color: {{ section.settings.content_text_color }};
      }

      /* Desktop panels */
      #{{ section_id }} .product-tabs-dynamic__panel--desktop[aria-hidden="false"] {
        display: block;
      }

      #{{ section_id }} .product-tabs-dynamic__panel--desktop[aria-hidden="true"] {
        display: none;
      }

      #{{ section_id }} .product-tabs-dynamic__panel--mobile,
      #{{ section_id }} .product-tabs-dynamic__accordion-item {
        display: none;
      }

      /* Mobile accordion */
      @media screen and (max-width: 699px) {
        #{{ section_id }} {
          padding-left: {{ section.settings.spacing_left_mobile }}px;
          padding-right: {{ section.settings.spacing_right_mobile }}px;
        }

        #{{ section_id }} .product-tabs-dynamic__nav {
          display: none;
        }

        #{{ section_id }} .product-tabs-dynamic__panel--desktop {
          display: none !important;
        }

        #{{ section_id }} .product-tabs-dynamic {
          display: flex;
          flex-direction: column;
        }

        #{{ section_id }} .product-tabs-dynamic__accordion-item {
          display: block;
          overflow: hidden;
          border-bottom: 1px solid #ddd;
        }

        #{{ section_id }} .product-tabs-dynamic__accordion-item:first-of-type {
          border-top: 1px solid #ddd;
        }

        #{{ section_id }} .product-tabs-dynamic__accordion-header {
          width: 100%;
          display: flex;
          justify-content: space-between;
          align-items: center;
          padding: 16px 0;
          background: transparent;
          border: none;
          font-family: inherit;
          font-size: {{ section.settings.tab_font_size_mobile }}px;
          font-weight: {{ section.settings.tab_font_weight }};
          cursor: pointer;
          text-align: left;
          color: {{ section.settings.tab_text_color }};
          transition: color 0.2s;
        }

        #{{ section_id }} .product-tabs-dynamic__accordion-header[aria-expanded="true"] {
          color: {{ section.settings.tab_underline_color | default: section.settings.tab_active_text_color }};
        }

        #{{ section_id }} .product-tabs-dynamic__accordion-icon {
          width: 0.75rem;
          height: 0.75rem;
          display: block;
          position: relative;
          flex-shrink: 0;
          margin-left: 10px;
        }

        #{{ section_id }} .product-tabs-dynamic__accordion-icon::before,
        #{{ section_id }} .product-tabs-dynamic__accordion-icon::after {
          content: "";
          background-color: currentColor;
          transition: transform 0.25s ease-in-out, opacity 0.25s ease-in-out;
          position: absolute;
          top: 50%;
          left: 50%;
          transform: translate(-50%, -50%);
        }

        #{{ section_id }} .product-tabs-dynamic__accordion-icon::before {
          width: 0.75rem;
          height: 1px;
        }

        #{{ section_id }} .product-tabs-dynamic__accordion-icon::after {
          height: 0.75rem;
          width: 1px;
        }

        #{{ section_id }} .product-tabs-dynamic__accordion-header[aria-expanded="true"] .product-tabs-dynamic__accordion-icon::after {
          transform: translate(-50%, -50%) rotate(90deg);
          opacity: 0;
        }

        #{{ section_id }} .product-tabs-dynamic__panel.product-tabs-dynamic__panel--mobile {
          display: block !important;
          height: 0;
          padding: 0;
          top: 0;
          border-radius: 0;
          overflow: hidden;
          opacity: 0;
        }

        #{{ section_id }} .product-tabs-dynamic__panel--mobile .prose,
        #{{ section_id }} .product-tabs-dynamic__panel--mobile .product-recipes-tab {
          padding-bottom: 16px;
          transform: translateY(4px);
        }
      }
    </style>

    <div id="{{ section_id }}" class="section-{{ section.id }}">
      <div class="product-tabs-dynamic">
        <div class="product-tabs-dynamic__nav" role="tablist">
          {%- for block in section.blocks -%}
            {%- assign tab_has_content = false -%}

            {%- if block.type == 'recipes' -%}
              {%- if product.metafields.custom.recipes.value != blank -%}
                {%- assign tab_has_content = true -%}
              {%- endif -%}
            {%- elsif block.settings.content_source == 'richtext' and block.settings.richtext_content != blank -%}
              {%- assign tab_has_content = true -%}
            {%- elsif block.settings.content_source == 'metafield' and block.settings.metafield_namespace != blank and block.settings.metafield_key != blank -%}
              {%- assign metafield_check = product.metafields[block.settings.metafield_namespace][block.settings.metafield_key] -%}
              {%- if metafield_check != blank and metafield_check.value != blank -%}
                {%- assign tab_has_content = true -%}
              {%- endif -%}
            {%- endif -%}

            {%- if tab_has_content and block.settings.tab_title != blank -%}
              {%- assign is_first_tab = false -%}
              {%- if forloop.first -%}
                {%- assign is_first_tab = true -%}
              {%- endif -%}

              <button
                class="product-tabs-dynamic__btn"
                role="tab"
                aria-selected="{% if is_first_tab %}true{% else %}false{% endif %}"
                aria-controls="{{ section_id }}-panel-{{ forloop.index }}"
                id="{{ section_id }}-tab-{{ forloop.index }}"
                type="button"
                {{ block.shopify_attributes }}
              >
                {{- block.settings.tab_title -}}
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- comment -%}Desktop Panels{%- endcomment -%}
        {%- assign panel_counter = 0 -%}
        {%- for block in section.blocks -%}
          {%- assign tab_content = '' -%}
          {%- assign is_recipes_block = false -%}

          {%- if block.type == 'recipes' -%}
            {%- assign is_recipes_block = true -%}
          {%- elsif block.settings.content_source == 'richtext' -%}
            {%- assign tab_content = block.settings.richtext_content -%}
          {%- elsif block.settings.content_source == 'metafield' and block.settings.metafield_namespace != blank and block.settings.metafield_key != blank -%}
            {%- assign metafield_value = product.metafields[block.settings.metafield_namespace][block.settings.metafield_key] -%}

            {%- if metafield_value != blank -%}
              {%- if metafield_value.type == 'rich_text_field' -%}
                {%- assign tab_content = metafield_value.value -%}
              {%- elsif metafield_value.type == 'single_line_text_field' or metafield_value.type == 'multi_line_text_field' -%}
                {%- capture tab_content -%}<p>{{ metafield_value.value }}</p>{%- endcapture -%}
              {%- elsif metafield_value.type == 'list.single_line_text_field' -%}
                {%- capture tab_content -%}
                  {%- for item in metafield_value.value -%}
                    <p>{{ item }}</p>
                  {%- endfor -%}
                {%- endcapture -%}
              {%- else -%}
                {%- assign tab_content = metafield_value.value -%}
              {%- endif -%}
            {%- endif -%}
          {%- endif -%}

          {%- assign tab_content = tab_content | strip -%}

          {%- if is_recipes_block and block.settings.tab_title != blank -%}
            {%- assign panel_counter = panel_counter | plus: 1 -%}
            {%- assign is_first_panel = false -%}
            {%- if panel_counter == 1 -%}
              {%- assign is_first_panel = true -%}
            {%- endif -%}

            <div
              class="product-tabs-dynamic__panel product-tabs-dynamic__panel--desktop"
              role="tabpanel"
              id="{{ section_id }}-panel-{{ forloop.index }}"
              aria-labelledby="{{ section_id }}-tab-{{ forloop.index }}"
              aria-hidden="{% if is_first_panel %}false{% else %}true{% endif %}"

            >
              {%- render 'product-recipes-tab', recipes: product.metafields.custom.recipes.value, section_id: section_id -%}
            </div>
          {%- elsif tab_content != blank and block.settings.tab_title != blank -%}
            {%- assign panel_counter = panel_counter | plus: 1 -%}
            {%- assign is_first_panel = false -%}
            {%- if panel_counter == 1 -%}
              {%- assign is_first_panel = true -%}
            {%- endif -%}

            <div
              class="product-tabs-dynamic__panel product-tabs-dynamic__panel--desktop"
              role="tabpanel"
              id="{{ section_id }}-panel-{{ forloop.index }}"
              aria-labelledby="{{ section_id }}-tab-{{ forloop.index }}"
              aria-hidden="{% if is_first_panel %}false{% else %}true{% endif %}"
            >
              <div class="prose">{{ tab_content }}</div>
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%}Mobile Accordion Items{%- endcomment -%}
        {%- assign mobile_panel_counter = 0 -%}
        {%- for block in section.blocks -%}
          {%- assign tab_content = '' -%}
          {%- assign is_recipes_block_mobile = false -%}

          {%- if block.type == 'recipes' -%}
            {%- if product.metafields.custom.recipes.value != blank -%}
              {%- assign is_recipes_block_mobile = true -%}
            {%- endif -%}
          {%- elsif block.settings.content_source == 'richtext' -%}
            {%- assign tab_content = block.settings.richtext_content -%}
          {%- elsif block.settings.content_source == 'metafield' and block.settings.metafield_namespace != blank and block.settings.metafield_key != blank -%}
            {%- assign metafield_value = product.metafields[block.settings.metafield_namespace][block.settings.metafield_key] -%}

            {%- if metafield_value != blank -%}
              {%- if metafield_value.type == 'rich_text_field' -%}
                {%- assign tab_content = metafield_value.value -%}
              {%- elsif metafield_value.type == 'single_line_text_field' or metafield_value.type == 'multi_line_text_field' -%}
                {%- capture tab_content -%}<p>{{ metafield_value.value }}</p>{%- endcapture -%}
              {%- elsif metafield_value.type == 'list.single_line_text_field' -%}
                {%- capture tab_content -%}
                  {%- for item in metafield_value.value -%}
                    <p>{{ item }}</p>
                  {%- endfor -%}
                {%- endcapture -%}
              {%- else -%}
                {%- assign tab_content = metafield_value.value -%}
              {%- endif -%}
            {%- endif -%}
          {%- endif -%}

          {%- assign tab_content = tab_content | strip -%}

          {%- if is_recipes_block_mobile and block.settings.tab_title != blank -%}
            {%- assign mobile_panel_counter = mobile_panel_counter | plus: 1 -%}

            <div class="product-tabs-dynamic__accordion-item">
              <button
                class="product-tabs-dynamic__accordion-header"
                type="button"
                aria-expanded="false"
                aria-controls="{{ section_id }}-mobile-panel-{{ forloop.index }}"
                data-accordion-trigger
              >
                <span>{{ block.settings.tab_title }}</span>
                <span class="product-tabs-dynamic__accordion-icon"></span>
              </button>

              <div
                class="product-tabs-dynamic__panel product-tabs-dynamic__panel--mobile"
                role="tabpanel"
                id="{{ section_id }}-mobile-panel-{{ forloop.index }}"
                aria-hidden="true"
              >
                {%- render 'product-recipes-tab', recipes: product.metafields.custom.recipes.value, section_id: section_id -%}
              </div>
            </div>
          {%- elsif tab_content != blank and block.settings.tab_title != blank -%}
            {%- assign mobile_panel_counter = mobile_panel_counter | plus: 1 -%}

            <div class="product-tabs-dynamic__accordion-item">
              <button
                class="product-tabs-dynamic__accordion-header"
                type="button"
                aria-expanded="false"
                aria-controls="{{ section_id }}-mobile-panel-{{ forloop.index }}"
                data-accordion-trigger
              >
                <span>{{ block.settings.tab_title }}</span>
                <span class="product-tabs-dynamic__accordion-icon"></span>
              </button>

              <div
                class="product-tabs-dynamic__panel product-tabs-dynamic__panel--mobile"
                role="tabpanel"
                id="{{ section_id }}-mobile-panel-{{ forloop.index }}"
                aria-hidden="true"
              >
                <div class="prose">{{ tab_content }}</div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <script>
      (function() {
        var container = document.getElementById('{{ section_id }}');
        if (!container) return;

        var tabs = container.querySelectorAll('[role="tab"]');
        var desktopPanels = container.querySelectorAll('.product-tabs-dynamic__panel--desktop');
        var accordionTriggers = container.querySelectorAll('[data-accordion-trigger]');

        {%- comment -%}Desktop tab functionality{%- endcomment -%}
        tabs.forEach(function(tab) {
          tab.addEventListener('click', function() {
            tabs.forEach(function(t) { t.setAttribute('aria-selected', 'false'); });
            desktopPanels.forEach(function(p) { p.setAttribute('aria-hidden', 'true'); });

            tab.setAttribute('aria-selected', 'true');
            var panelId = tab.getAttribute('aria-controls');
            var panel = document.getElementById(panelId);
            if (panel && panel.classList.contains('product-tabs-dynamic__panel--desktop')) {
              panel.setAttribute('aria-hidden', 'false');
            }
          });
        });

        {%- comment -%}Keyboard navigation for desktop{%- endcomment -%}
        tabs.forEach(function(tab, index) {
          tab.addEventListener('keydown', function(e) {
            var direction = null;
            if (e.key === 'ArrowLeft') direction = -1;
            if (e.key === 'ArrowRight') direction = 1;

            if (direction !== null) {
              e.preventDefault();
              var nextIndex = (index + direction + tabs.length) % tabs.length;
              tabs[nextIndex].click();
              tabs[nextIndex].focus();
            }
          });
        });

        {%- comment -%}Mobile accordion functionality{%- endcomment -%}
        function initMobileAccordion() {
          if (window.innerWidth > 699) return;

          accordionTriggers.forEach(function(trigger, index) {
            var panelId = trigger.getAttribute('aria-controls');
            var panel = document.getElementById(panelId);

            if (panel) {
              {
                trigger.setAttribute('aria-expanded', 'false');
                panel.style.height = '0px';
                panel.style.opacity = '0';
                panel.setAttribute('aria-hidden', 'true');
              }
            }
          });
        }

        {%- comment -%}Initialize on load{%- endcomment -%}
        initMobileAccordion();

        {%- comment -%}Re-initialize on resize{%- endcomment -%}
        var resizeTimer;
        window.addEventListener('resize', function() {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(function() {
            if (window.innerWidth > 699) {
              {%- comment -%}Reset panels for desktop{%- endcomment -%}
              accordionTriggers.forEach(function(trigger) {
                var panelId = trigger.getAttribute('aria-controls');
                var panel = document.getElementById(panelId);
                if (panel) {
                  panel.style.height = '';
                  panel.style.opacity = '';
                  panel.style.paddingTop = '';
                  panel.style.paddingBottom = '';
                }
              });
            } else {
              initMobileAccordion();
            }
          }, 250);
        });

        accordionTriggers.forEach(function(trigger) {
          trigger.addEventListener('click', function() {
            if (window.innerWidth > 699) return;

            var panelId = trigger.getAttribute('aria-controls');
            var panel = document.getElementById(panelId);
            var content = panel ? (panel.querySelector('.prose') || panel.querySelector('.product-recipes-tab')) : null;

            if (!panel || !content) return;

            var isExpanded = trigger.getAttribute('aria-expanded') === 'true';

            if (isExpanded) {
              {%- comment -%}Close animation{%- endcomment -%}
              trigger.setAttribute('aria-expanded', 'false');

              var currentHeight = panel.scrollHeight;

              {%- comment -%}Animate panel opacity{%- endcomment -%}
              panel.animate([
                { opacity: 1 },
                { opacity: 0 }
              ], {
                duration: 150,
                easing: 'ease',
                fill: 'forwards'
              });

              {%- comment -%}Animate content{%- endcomment -%}
              content.animate([
                { transform: 'translateY(0)' },
                { transform: 'translateY(4px)' }
              ], {
                duration: 150,
                easing: 'ease',
                fill: 'forwards'
              });

              {%- comment -%}Animate height collapse{%- endcomment -%}
              var heightAnimation = panel.animate([
                { height: currentHeight + 'px', paddingTop: '{{ section.settings.content_padding_mobile }}px', paddingBottom: '{{ section.settings.content_padding_mobile }}px' },
                { height: '0px', paddingTop: '0px', paddingBottom: '0px' }
              ], {
                duration: 250,
                easing: 'ease',
                fill: 'forwards'
              });

              heightAnimation.finished.then(function() {
                panel.setAttribute('aria-hidden', 'true');
                panel.style.height = '0px';
                panel.style.paddingTop = '0px';
                panel.style.paddingBottom = '0px';
              });

            } else {
              {%- comment -%}Open animation{%- endcomment -%}
              trigger.setAttribute('aria-expanded', 'true');
              panel.setAttribute('aria-hidden', 'false');

              {%- comment -%}Get the full height{%- endcomment -%}
              panel.style.height = 'auto';
              panel.style.paddingTop = '{{ section.settings.content_padding_mobile }}px';
              panel.style.paddingBottom = '{{ section.settings.content_padding_mobile }}px';
              var fullHeight = panel.scrollHeight;
              panel.style.height = '0px';
              panel.style.paddingTop = '0px';
              panel.style.paddingBottom = '0px';

              {%- comment -%}Force reflow{%- endcomment -%}
              panel.offsetHeight;

              {%- comment -%}Animate height expansion{%- endcomment -%}
              panel.animate([
                { height: '0px', paddingTop: '0px', paddingBottom: '0px' },
                { height: fullHeight + 'px', paddingTop: '{{ section.settings.content_padding_mobile }}px', paddingBottom: '{{ section.settings.content_padding_mobile }}px' }
              ], {
                duration: 250,
                easing: 'ease',
                fill: 'forwards'
              });

              {%- comment -%}Animate panel opacity{%- endcomment -%}
              setTimeout(function() {
                panel.animate([
                  { opacity: 0 },
                  { opacity: 1 }
                ], {
                  duration: 150,
                  easing: 'ease',
                  fill: 'forwards'
                });
              }, 100);

              {%- comment -%}Animate content fade in{%- endcomment -%}
              setTimeout(function() {
                content.animate([
                  { transform: 'translateY(4px)' },
                  { transform: 'translateY(0)' }
                ], {
                  duration: 150,
                  easing: 'ease',
                  fill: 'forwards'
                });
              }, 100);
            }
          });
        });
      })();
    </script>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Product Tabs",
  "tag": "section",
  "class": "shopify-section--product-tabs-dynamic",
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "spacing_left",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Left spacing (Desktop)",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing_right",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Right spacing (Desktop)",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing_left_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Left spacing (Mobile)",
      "default": 15
    },
    {
      "type": "range",
      "id": "spacing_right_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Right spacing (Mobile)",
      "default": 15
    },
    {
      "type": "range",
      "id": "spacing_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top spacing",
      "default": 40
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 40
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Tab Styling"
    },
    {
      "type": "range",
      "id": "tab_gap",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Tab gap (Desktop)",
      "default": 20
    },
    {
      "type": "range",
      "id": "tab_gap_mobile",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Tab gap (Mobile)",
      "default": 10
