{% doc %}
  @prompt
    ingredients list, move ingredients header to middle and make H4
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ingredients-list-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-ingredients-list__header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.header_spacing }}px;
    text-align: center;
  }

  .ai-ingredients-list__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 8px 0;
    text-transform: {{ block.settings.title_transform }};
    letter-spacing: 0.05em;
  }

  .ai-ingredients-list__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    font-style: italic;
  }

  .ai-ingredients-list__items-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-ingredients-list__item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: {{ block.settings.item_padding }}px 0;
    border-bottom: {{ block.settings.show_dividers }}px solid {{ block.settings.divider_color }};
  }

  .ai-ingredients-list__item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-ingredients-list__bullet-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.bullet_size }}px;
    height: {{ block.settings.bullet_size }}px;
    margin-top: 4px;
  }

  .ai-ingredients-list__bullet-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.bullet_color }};
  }

  .ai-ingredients-list__content-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-ingredients-list__name-{{ ai_gen_id }} {
    font-size: {{ block.settings.ingredient_size }}px;
    color: {{ block.settings.ingredient_color }};
    font-weight: {{ block.settings.ingredient_weight }};
    margin: 0 0 4px 0;
  }

  .ai-ingredients-list__amount-{{ ai_gen_id }} {
    font-size: {{ block.settings.amount_size }}px;
    color: {{ block.settings.amount_color }};
    margin: 0;
  }

  .ai-ingredients-list__notes-{{ ai_gen_id }} {
    margin-top: {{ block.settings.notes_spacing }}px;
    padding-top: {{ block.settings.notes_spacing }}px;
    border-top: 1px solid {{ block.settings.divider_color }};
    font-size: {{ block.settings.notes_size }}px;
    color: {{ block.settings.notes_color }};
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-ingredients-list__items-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-ingredients-list__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.85);
    }

    .ai-ingredients-list-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-ingredients-list-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank or block.settings.subtitle != blank %}
    <div class="ai-ingredients-list__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h4 class="ai-ingredients-list__title-{{ ai_gen_id }}">{{ block.settings.title }}</h4>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-ingredients-list__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  <ul class="ai-ingredients-list__items-{{ ai_gen_id }}">
    {% for i in (1..12) %}
      {% assign ingredient_key = 'ingredient_' | append: i %}
      {% assign amount_key = 'amount_' | append: i %}
      {% assign ingredient = block.settings[ingredient_key] %}
      {% assign amount = block.settings[amount_key] %}
      
      {% if ingredient != blank %}
        <li class="ai-ingredients-list__item-{{ ai_gen_id }}">
          <div class="ai-ingredients-list__bullet-{{ ai_gen_id }}">
            {% if block.settings.bullet_style == 'check' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            {% elsif block.settings.bullet_style == 'dot' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="4"></circle>
              </svg>
            {% elsif block.settings.bullet_style == 'dash' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
            {% endif %}
          </div>
          <div class="ai-ingredients-list__content-{{ ai_gen_id }}">
            <p class="ai-ingredients-list__name-{{ ai_gen_id }}">{{ ingredient }}</p>
            {% if amount != blank %}
              <p class="ai-ingredients-list__amount-{{ ai_gen_id }}">{{ amount }}</p>
            {% endif %}
          </div>
        </li>
      {% endif %}
    {% endfor %}
  </ul>

  {% if block.settings.notes != blank %}
    <div class="ai-ingredients-list__notes-{{ ai_gen_id }}">
      {{ block.settings.notes }}
    </div>
  {% endif %}
</div>

