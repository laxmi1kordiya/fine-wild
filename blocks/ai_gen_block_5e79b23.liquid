{% doc %}
  @prompt
    make a step section upto 10 all with the ability to add a square image that works well in desktop and mobile 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-steps-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-steps-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-steps-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-steps-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px 0;
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
  }

  .ai-steps-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
  }

  .ai-steps-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_spacing }}px;
  }

  .ai-step-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.step_content_gap }}px;
  }

  .ai-step-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: {{ block.settings.image_placeholder_bg }};
  }

  .ai-step-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-step-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.image_placeholder_bg }};
  }

  .ai-step-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-step-number-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.number_position_top }}px;
    left: {{ block.settings.number_position_left }}px;
    width: {{ block.settings.number_size }}px;
    height: {{ block.settings.number_size }}px;
    background-color: {{ block.settings.number_bg_color }};
    color: {{ block.settings.number_text_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: {{ block.settings.number_font_size }}px;
  }

  .ai-step-content-{{ ai_gen_id }} {
    text-align: {{ block.settings.step_text_alignment }};
  }

  .ai-step-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.step_title_size }}px;
    color: {{ block.settings.step_title_color }};
    margin: 0 0 8px 0;
    font-weight: 600;
  }

  .ai-step-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.step_description_size }}px;
    color: {{ block.settings.step_description_color }};
    margin: 0;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-steps-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-steps-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-step-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.step_title_size }}px * 0.9);
    }

    .ai-step-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.step_description_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-steps-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-steps-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank or block.settings.section_description != blank %}
      <div class="ai-steps-header-{{ ai_gen_id }}">
        {% if block.settings.section_title != blank %}
          <h2 class="ai-steps-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% endif %}
        {% if block.settings.section_description != blank %}
          <div class="ai-steps-description-{{ ai_gen_id }}">{{ block.settings.section_description }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-steps-grid-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {% liquid
          assign step_enabled_key = 'step_' | append: i | append: '_enabled'
          assign step_image_key = 'step_' | append: i | append: '_image'
          assign step_title_key = 'step_' | append: i | append: '_title'
          assign step_description_key = 'step_' | append: i | append: '_description'

          assign step_enabled = block.settings[step_enabled_key]
          assign step_image = block.settings[step_image_key]
          assign step_title = block.settings[step_title_key]
          assign step_description = block.settings[step_description_key]
        %}

        {% if step_enabled %}
          <div class="ai-step-item-{{ ai_gen_id }}">
            <div class="ai-step-image-wrapper-{{ ai_gen_id }}">
              {% if step_image %}
                <img
                  src="{{ step_image | image_url: width: 800 }}"
                  alt="{{ step_image.alt | escape }}"
                  loading="lazy"
                  width="800"
                  height="800"
                  class="ai-step-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-step-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
              {% if block.settings.show_step_numbers %}
                <div class="ai-step-number-{{ ai_gen_id }}">{{ i }}</div>
              {% endif %}
            </div>
            <div class="ai-step-content-{{ ai_gen_id }}">
              {% if step_title != blank %}
                <h3 class="ai-step-title-{{ ai_gen_id }}">{{ step_title }}</h3>
              {% endif %}
              {% if step_description != blank %}
                <div class="ai-step-description-{{ ai_gen_id }}">{{ step_description }}</div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

