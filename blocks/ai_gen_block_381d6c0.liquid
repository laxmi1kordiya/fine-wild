    {
      "type": "header",
      "content": "Product card"
    },
    {
      "type": "range",
      "id": "product_title_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Product title size",
      "default": 14
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
