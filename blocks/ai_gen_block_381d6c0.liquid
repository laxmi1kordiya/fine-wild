{% doc %}
  @prompt
    frestured products (with quick add to cart) these need to be able to have a collection attached, keep this on btrand please like the recently viewed products section above (note font size and stytle , Font for product Montserrat semi bold and option to alter font size, make scrollable (carousel content)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-products-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    overflow: hidden;
  }

  .ai-featured-products__container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-featured-products__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-featured-products__heading-{{ ai_gen_id }} {
    font-family: var(--heading-font-family);
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    text-transform: var(--heading-text-transform);
    letter-spacing: var(--heading-letter-spacing);
    font-weight: 600;
  }

  .ai-featured-products__carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-featured-products__carousel-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.grid_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 10px;
  }

  .ai-featured-products__carousel-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-featured-products__item-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    width: calc((100% - {{ block.settings.grid_gap }}px) / {{ block.settings.products_per_row_mobile }});
  }

  @media screen and (min-width: 750px) {
    .ai-featured-products__item-{{ ai_gen_id }} {
      width: calc((100% - ({{ block.settings.grid_gap }}px * ({{ block.settings.products_per_row_desktop }} - 1))) / {{ block.settings.products_per_row_desktop }});
    }
  }

  .ai-featured-products__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 0;
    background-color: #f4f4f4;
    margin-bottom: 16px;
  }

  .ai-featured-products__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-featured-products__item-{{ ai_gen_id }}:hover .ai-featured-products__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-featured-products__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-featured-products__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-featured-products__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 4px 10px;
    border-radius: 2px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-family: var(--heading-font-family);
  }

  .ai-featured-products__info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ai-featured-products__vendor-{{ ai_gen_id }} {
    font-size: 11px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-family: var(--heading-font-family);
    font-weight: 600;
  }

  .ai-featured-products__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.4;
    font-family: 'Montserrat', var(--heading-font-family);
    font-weight: 600;
  }

  .ai-featured-products__title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
  }

  .ai-featured-products__title-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-featured-products__price-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
    font-family: var(--heading-font-family);
    margin-top: 4px;
  }

  .ai-featured-products__price--compare-{{ ai_gen_id }} {
    text-decoration: line-through;
    opacity: 0.5;
    margin-right: 8px;
    font-weight: 400;
  }

  .ai-featured-products__price--sale-{{ ai_gen_id }} {
    color: {{ block.settings.sale_price_color }};
  }

  .ai-featured-products__quick-add-{{ ai_gen_id }} {
    margin-top: 12px;
  }

  .ai-featured-products__add-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 20px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: 30px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: var(--heading-font-family);
  }

  .ai-featured-products__add-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    transform: translateY(-2px);
  }

  .ai-featured-products__add-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .ai-featured-products__variant-select-{{ ai_gen_id }} {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 8px;
    margin-bottom: 8px;
    font-size: 13px;
    background-color: #ffffff;
    font-family: var(--text-font-family);
  }

  .ai-featured-products__nav-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: all 0.3s ease;
    opacity: 0.9;
  }

  .ai-featured-products__nav-button-{{ ai_gen_id }}:hover {
    opacity: 1;
    transform: translateY(-50%) scale(1.1);
  }

  .ai-featured-products__nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-featured-products__nav-button--prev-{{ ai_gen_id }} {
    left: -20px;
  }

  .ai-featured-products__nav-button--next-{{ ai_gen_id }} {
    right: -20px;
  }

  .ai-featured-products__nav-button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-featured-products__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  .ai-featured-products__empty-state-{{ ai_gen_id }} p {
    margin: 0;
    font-size: 14px;
    font-family: var(--text-font-family);
  }

  @media screen and (max-width: 749px) {
    .ai-featured-products__nav-button-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<featured-products-{{ ai_gen_id }} class="ai-featured-products-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-products__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-featured-products__header-{{ ai_gen_id }}">
        <h2 class="ai-featured-products__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      </div>
    {% endif %}

    {% if block.settings.collection != blank %}
      {% assign collection = block.settings.collection %}
      {% assign products_to_show = block.settings.products_to_show %}
      
      {% if collection.products.size > 0 %}
        <div class="ai-featured-products__carousel-wrapper-{{ ai_gen_id }}">
          <button
            class="ai-featured-products__nav-button-{{ ai_gen_id }} ai-featured-products__nav-button--prev-{{ ai_gen_id }}"
            aria-label="Previous products"
            data-direction="prev"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>

          <div class="ai-featured-products__carousel-{{ ai_gen_id }}">
            {% for product in collection.products limit: products_to_show %}
              <div class="ai-featured-products__item-{{ ai_gen_id }}">
                <div class="ai-featured-products__image-wrapper-{{ ai_gen_id }}">
                  <a href="{{ product.url }}">
                    {% if product.featured_image %}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        alt="{{ product.featured_image.alt | escape }}"
                        class="ai-featured-products__image-{{ ai_gen_id }}"
                        loading="lazy"
                        width="600"
                        height="600"
                      >
                    {% else %}
                      <div class="ai-featured-products__image-placeholder-{{ ai_gen_id }}">
                        {{ 'product-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </a>

                  {% if block.settings.show_badges %}
                    {% if product.available == false %}
                      <span class="ai-featured-products__badge-{{ ai_gen_id }}">Sold out</span>
                    {% elsif product.compare_at_price > product.price %}
                      <span class="ai-featured-products__badge-{{ ai_gen_id }}">Sale</span>
                    {% endif %}
                  {% endif %}
                </div>

                <div class="ai-featured-products__info-{{ ai_gen_id }}">
                  {% if block.settings.show_vendor and product.vendor != blank %}
                    <div class="ai-featured-products__vendor-{{ ai_gen_id }}">{{ product.vendor }}</div>
                  {% endif %}

                  <h3 class="ai-featured-products__title-{{ ai_gen_id }}">
                    <a href="{{ product.url }}" class="ai-featured-products__title-link-{{ ai_gen_id }}">
                      {{ product.title }}
                    </a>
                  </h3>

                  <div class="ai-featured-products__price-{{ ai_gen_id }}">
                    {% if product.compare_at_price > product.price %}
                      <span class="ai-featured-products__price--compare-{{ ai_gen_id }}">
                        {{ product.compare_at_price | money }}
                      </span>
                      <span class="ai-featured-products__price--sale-{{ ai_gen_id }}">
                        {{ product.price | money }}
                      </span>
                    {% else %}
                      {{ product.price | money }}
                    {% endif %}
                  </div>

                  {% if block.settings.show_quick_add %}
                    <div class="ai-featured-products__quick-add-{{ ai_gen_id }}">
                      {% if product.available %}
                        {% if product.variants.size > 1 %}
                          <select
                            class="ai-featured-products__variant-select-{{ ai_gen_id }}"
                            data-product-id="{{ product.id }}"
                            aria-label="Select variant for {{ product.title }}"
                          >
                            {% for variant in product.variants %}
                              <option
                                value="{{ variant.id }}"
                                {% unless variant.available %}disabled{% endunless %}
                              >
                                {{ variant.title }}
                                {% unless variant.available %} - Sold out{% endunless %}
                              </option>
                            {% endfor %}
                          </select>
                        {% endif %}

                        <button
                          class="ai-featured-products__add-button-{{ ai_gen_id }}"
                          data-product-id="{{ product.id }}"
                          data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                          aria-label="Add {{ product.title }} to cart"
                        >
                          {{ block.settings.add_to_cart_text }}
                        </button>
                      {% else %}
                        <button
                          class="ai-featured-products__add-button-{{ ai_gen_id }}"
                          disabled
                        >
                          Sold out
                        </button>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>

          <button
            class="ai-featured-products__nav-button-{{ ai_gen_id }} ai-featured-products__nav-button--next-{{ ai_gen_id }}"
            aria-label="Next products"
            data-direction="next"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>
      {% else %}
        <div class="ai-featured-products__empty-state-{{ ai_gen_id }}">
          <p>This collection is empty. Add products to display them here.</p>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-featured-products__empty-state-{{ ai_gen_id }}">
        <p>Select a collection to display featured products</p>
      </div>
    {% endif %}
  </div>
</featured-products-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedProducts{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupQuickAdd();
        this.setupCarousel();
      }

      setupCarousel() {
        const carousel = this.querySelector('.ai-featured-products__carousel-{{ ai_gen_id }}');
        const prevButton = this.querySelector('.ai-featured-products__nav-button--prev-{{ ai_gen_id }}');
        const nextButton = this.querySelector('.ai-featured-products__nav-button--next-{{ ai_gen_id }}');

        if (!carousel || !prevButton || !nextButton) return;

        const updateButtons = () => {
          const scrollLeft = carousel.scrollLeft;
          const maxScroll = carousel.scrollWidth - carousel.clientWidth;

          prevButton.disabled = scrollLeft <= 0;
          nextButton.disabled = scrollLeft >= maxScroll - 1;
        };

        prevButton.addEventListener('click', () => {
          const scrollAmount = carousel.clientWidth * 0.8;
          carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        });

        nextButton.addEventListener('click', () => {
          const scrollAmount = carousel.clientWidth * 0.8;
          carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        });

        carousel.addEventListener('scroll', updateButtons);
        updateButtons();
      }

      setupQuickAdd() {
        const addButtons = this.querySelectorAll('.ai-featured-products__add-button-{{ ai_gen_id }}');
        const variantSelects = this.querySelectorAll('.ai-featured-products__variant-select-{{ ai_gen_id }}');

        variantSelects.forEach((select) => {
          select.addEventListener('change', (e) => {
            const productId = e.target.dataset.productId;
            const button = this.querySelector(
              `.ai-featured-products__add-button-{{ ai_gen_id }}[data-product-id="${productId}"]`
            );
            if (button) {
              button.dataset.variantId = e.target.value;
            }
          });
        });

        addButtons.forEach((button) => {
          button.addEventListener('click', (e) => {
            this.addToCart(e.target);
          });
        });
      }

      async addToCart(button) {
        if (button.disabled) return;

        const variantId = button.dataset.variantId;
        const originalText = button.textContent;

        button.disabled = true;
        button.textContent = 'Adding...';

        try {
          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              id: variantId,
              quantity: 1,
            }),
          });

          if (!response.ok) {
            throw new Error('Failed to add to cart');
          }

          button.textContent = 'Added!';

          setTimeout(() => {
            button.textContent = originalText;
            button.disabled = false;
          }, 2000);

          document.dispatchEvent(new CustomEvent('cart:refresh'));

          const cartDrawer = document.querySelector('cart-drawer');
          if (cartDrawer) {
            cartDrawer.open();
          }
        } catch (error) {
          console.error('Error adding to cart:', error);
          button.textContent = 'Error';
          setTimeout(() => {
            button.textContent = originalText;
            button.disabled = false;
          }, 2000);
        }
      }
    }

    customElements.define('featured-products-{{ ai_gen_id }}', FeaturedProducts{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Featured products",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 24
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Heading spacing",
      "default": 25
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "products_per_row_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
