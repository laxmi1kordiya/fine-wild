      "id": "ingredients",
      "label": "Ingredients",
      "placeholder": "500g Wagyu beef, 2 tbsp soy sauce, 1 cup dashi, 4 shiitake mushrooms",
      "info": "Enter each ingredient separated by a comma. Each ingredient will appear as a bullet point."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
