{% doc %}
  @prompt
    Create a blog post article section for recipe content with the following features:
    - Separate image pickers for desktop and mobile versions (desktop image and mobile image fields)
    - Responsive image display that shows the mobile image on mobile devices and desktop image on larger screens
    - Article title, author, date, and content display
    - Image size options (small, medium, large, full-width)
    - Toggle to show/hide the featured image
    - Clean, premium styling suitable for a luxury food/recipe blog
    - Proper semantic HTML structure for blog articles, great then add ingredinets block so we can enter each one and press commar and has them in a bullet point lst
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ingredients-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-ingredients__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-ingredients__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size_mobile }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    line-height: 1.3;
    letter-spacing: {{ block.settings.heading_letter_spacing }}%;
  }

  @media screen and (min-width: 750px) {
    .ai-ingredients__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_desktop }}px;
    }
  }

  .ai-ingredients__list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-ingredients__item-{{ ai_gen_id }} {
    position: relative;
    padding-left: {{ block.settings.bullet_spacing }}px;
    margin-bottom: {{ block.settings.item_spacing }}px;
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-size: {{ block.settings.text_size_mobile }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
  }

  @media screen and (min-width: 750px) {
    .ai-ingredients__item-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_desktop }}px;
    }
  }

  .ai-ingredients__item-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-ingredients__item-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: {{ block.settings.bullet_size }}px;
    height: {{ block.settings.bullet_size }}px;
    background-color: {{ block.settings.bullet_color }};
    border-radius: {% if block.settings.bullet_style == 'circle' %}50%{% else %}0{% endif %};
    transform: translateY(-50%);
  }

  .ai-ingredients__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  .ai-ingredients__empty-state-title-{{ ai_gen_id }} {
    font-size: 16px;
    margin-bottom: 8px;
    font-weight: 600;
  }

  .ai-ingredients__empty-state-text-{{ ai_gen_id }} {
    font-size: 14px;
  }
{% endstyle %}

<div
  class="ai-ingredients-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-ingredients__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-ingredients__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.ingredients != blank %}
      {% assign ingredients_array = block.settings.ingredients | split: ',' %}
      <ul class="ai-ingredients__list-{{ ai_gen_id }}">
        {% for ingredient in ingredients_array %}
          {% assign trimmed_ingredient = ingredient | strip %}
          {% if trimmed_ingredient != blank %}
            <li class="ai-ingredients__item-{{ ai_gen_id }}">{{ trimmed_ingredient }}</li>
          {% endif %}
        {% endfor %}
      </ul>
    {% else %}
      <div class="ai-ingredients__empty-state-{{ ai_gen_id }}">
        <div class="ai-ingredients__empty-state-title-{{ ai_gen_id }}">
          No ingredients added yet
        </div>
        <div class="ai-ingredients__empty-state-text-{{ ai_gen_id }}">
          Enter ingredients separated by commas (e.g., 500g Wagyu beef, 2 tbsp soy sauce, 1 cup dashi)
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Recipe ingredients",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
